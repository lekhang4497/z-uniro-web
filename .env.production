# Default backend URL baked into production builds (web + desktop static export).
# Dev builds (`npm run dev`) ignore this file and fall back to localhost:8857.
# Users can override per-install via Settings → Backend (writes to localStorage).
# CI also overrides this with `vars.NEXT_PUBLIC_BACKEND_URL` if set in repo settings.
NEXT_PUBLIC_BACKEND_URL=https://api.uniro.tech
